DB_HOST=localhost
DB_PORT=5432
DB_NAME=coreme
DB_USER=postgres
DB_PASSWORD=postgres
REDIS_URL=redis://localhost:6379
JWT_SECRET=your_secret_key_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# Go REST API port
API_PORT=3001
# Node.js realtime port
REALTIME_PORT=3002

# Sentry — leave empty to disable (safe for dev/test)
SENTRY_DSN=
APP_ENV=development

# Firebase push notifications
FIREBASE_SERVICE_ACCOUNT_KEY=

# TURN server (WebRTC NAT traversal) — docker compose --profile turn up turn
TURN_USERNAME=coreme
TURN_PASSWORD=
TURN_REALM=coreme.app
TURN_PUBLIC_IP=

# Monitoring — Grafana / AlertManager (docker compose --profile observability up)
GRAFANA_PASSWORD=admin
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenTelemetry / Jaeger tracing
# Start Jaeger: docker compose --profile observability up jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=coreme-api

# NATS JetStream
NATS_URL=nats://localhost:4222

# Backups — Cloudflare R2
R2_BUCKET=coreme-backups
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
RETENTION_DAYS=30
